# =====================================================================
# Morvarid-Farm (SPA) — environment variable template.
# Copy to `.env` (gitignored) and fill in.
# In Render, set these names on the `morvarid-farm` Static Site only.
# DO NOT also place the service-role key here; it is held by the
# `morvarid-farm-bff` Web Service (see bff/.env.example).
# =====================================================================

# --- REQUIRED for the SPA build ------------------------------------
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- REQUIRED for admin operations ---------------------------------
# Base URL of the auth.admin BFF Web Service (the only place the
# Supabase service-role key is held).
# Render:  VITE_BFF_URL=https://morvarid-farm-bff.onrender.com
# Local:   VITE_BFF_URL=http://localhost:10000
VITE_BFF_URL=

# --- OPTIONAL ------------------------------------------------------
VITE_APP_VERSION=1.0.2
