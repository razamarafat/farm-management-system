# ──────────────────────────────────────────────────────────────────────────
# نمونه‌ی متغیرهای محیطی پروژه «مروارید فارم»
# این فایل را در ریشه‌ی پروژه با نام «.env» کپی کنید و مقادیر واقعی را وارد کنید.
# فایل .env هرگز نباید در گیت commit شود (در .gitignore قرار دارد).
# ──────────────────────────────────────────────────────────────────────────

# آدرس پروژه‌ی Supabase  (مثال: https://xxxx.supabase.co)
VITE_SUPABASE_URL=

# کلید عمومی anon  ← این کلید عمومی است و ارسال آن به مرورگر بی‌خطر است.
VITE_SUPABASE_ANON_KEY=

# ⚠️ هشدار امنیتی بسیار مهم ⚠️
# هر متغیری که با پیشوند VITE_ تعریف شود، توسط Vite داخل فایل خروجی (bundle)
# قرار می‌گیرد و برای همه‌ی کاربران در مرورگر قابل استخراج است.
# بنابراین قرار دادن service_role در یک متغیر VITE_ یعنی کلید مدیریتی پایگاه‌داده
# به‌طور عمومی در دسترس قرار می‌گیرد و امنیت کل دیتابیس از بین می‌رود.
#
# توصیه‌ی امنیتی:
#   ۱) این کلید را در محیط production تنظیم نکنید.
#   ۲) عملیات مدیریتی (ساخت/حذف کاربر، seed ادمین و …) را به Supabase Edge Function
#      منتقل کنید و سیاست‌های RLS را روی همه‌ی جدول‌ها فعال کنید.
#   ۳) جزئیات در فایل SECURITY.md آمده است.
# این متغیر فقط برای سازگاری با کد فعلی نگه داشته شده و باید در نسخه‌ی امن حذف شود.
VITE_SUPABASE_SERVICE_ROLE_KEY=

# اطلاعات کاربر ادمین اولیه (فقط برای راه‌اندازی اولیه).
# توجه: چون با پیشوند VITE_ هستند داخل bundle قرار می‌گیرند؛ در محیط امن باید
# ساخت ادمین از طریق سرور/Edge Function انجام شود (به SECURITY.md مراجعه کنید).
VITE_ADMIN_USERNAME=
VITE_ADMIN_PASSWORD=

# نسخه‌ی برنامه که در رابط کاربری نمایش داده می‌شود.
VITE_APP_VERSION=1.0.0
