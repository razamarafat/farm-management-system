# =====================================================================
# services/export-api/.env.example
#
# Required (read at startup; service crashes if missing).
# =====================================================================
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...   # anon key, safe to ship — never the service-role key

# Optional. When present, used only by future admin-bound flows
# (export audit log, etc.) — NOT used by regular query paths. Leave
# empty in dev; set in production only if you wire those flows.
# SUPABASE_SECRET_KEY=

# CORS allowlist (comma-sep). Defaults to '*' in dev ONLY when
# NODE_ENV !== 'production'. Lock this down to your SPA origin in prod.
ALLOWED_ORIGIN=http://localhost:5173,http://localhost:4173

# Server port (Render sets this automatically via PORT env var).
PORT=3000

# Node env. Render sets NODE_ENV=production on deploy.
NODE_ENV=development
