# ---------------------------------------------------------------
#  morvarid-farm-bff — environment variable template
#  Copy to `bff/.env` for local dev. In Render, set these on the
#  Web Service "morvarid-farm-bff" (do NOT also add them to the SPA's
#  Static Site env config — only the BFF needs the SERVICE_ROLE_KEY).
# ---------------------------------------------------------------

# Required: same Supabase project as the SPA.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Required: server-side only. NEVER bundle this into the SPA build.
# Use the new sb_secret_* key if your project supports it; otherwise
# keep using the legacy service-role key, which is held server-only here.
VITE_SUPABASE_SERVICE_ROLE_KEY=

# Recommended: lock CORS to the deployed SPA origin.
# For previews, allow the wildcard https://*-pr-*.onrender.com.
ALLOWED_ORIGIN=
