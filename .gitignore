# Node / build artefacts
/node_modules
/dist
.vite

# ---------------------------------------------------------------
# Environment variables — anything that can contain secrets.
# Matches all known variants (dot, dash, uppercase for tooling).
# ---------------------------------------------------------------
.env
.env.*
!.env.example
!.bff/.env.example
.envrc

# ---------------------------------------------------------------
# Repo hygiene: artefacts that have leaked secrets before.
# ---------------------------------------------------------------
# repo XML dumps (repomix) — these have historically mirrored .env.
repomix-output.xml
allcode.txt

# Migration/apply scripts + audit backups — contain live Supabase
# access tokens (sbp_...) used to run migrations. Local-only.
apply_reporting.sh
/backups/

# Windows CMD artefacts (the result of `> nul` redirections).
nul
tmp.js

# BFF local env (used by `cd bff && npm start`)
/bff/.env

# OS / IDE
.DS_Store
Thumbs.db
.vscode/
.idea/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Coverage / scratch
coverage
.cache
.parcel-cache
.next
